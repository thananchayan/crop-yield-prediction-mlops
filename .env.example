APP_NAME=Crop Yield Prediction API
APP_ENV=development
API_VERSION=v1.0.0
MODEL_VERSION=v3.0.0
MODEL_SOURCE=local
HF_MODEL_REPO_ID=your-username/crop-yield-regressor
HF_MODEL_REVISION=main
HF_MODEL_CACHE_DIR=.cache/hf_models
MODEL_PATH=artifacts/models/v1.0.0/crop_yield_model.joblib
MODEL_METADATA_PATH=artifacts/metrics/v1.0.0/model_metadata.json
PREPROCESSING_METADATA_PATH=artifacts/metrics/v1.0.0/preprocessing_metadata.json
FRONTEND_DIST_DIR=frontend/dist
PREDICTION_UNIT=hg/ha
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
